# =============================================================================
# FREE SETUP — Discord + Groq (LLM) + local embeddings
# =============================================================================

# REQUIRED: Discord bot token (free — https://discord.com/developers/applications)
DISCORD_TOKEN=your_discord_bot_token_here

# REQUIRED: Groq API key (free tier — https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here

# Groq chat model
GROQ_MODEL=llama-3.3-70b-versatile

# Local embedding model (ChromaDB ONNX, no API key)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Escalate to ticket when confidence is below this (0.0–1.0)
CONFIDENCE_THRESHOLD=0.75
